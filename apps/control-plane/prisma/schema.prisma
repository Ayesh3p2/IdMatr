generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLATFORM_ADMIN
  TENANT_ADMIN
  USER
  READONLY
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REVOKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
  FAILED
}

enum RequestType {
  ACCESS_REQUEST
  ROLE_CHANGE
  APP_ACCESS
}

enum EventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IntegrationProvider {
  GOOGLE
  MICROSOFT
  SLACK
  GITHUB
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

model Tenant {
  id           String            @id @default(uuid())
  name         String
  slug         String            @unique
  primaryDomain String?          @map("primary_domain")
  status       TenantStatus      @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  users        TenantUser[]
  invites      Invite[]
  reviews      AccessReview[]
  requests     IdentityRequest[]
  integrations Integration[]
  events       AuditEvent[]
  identities   ExternalIdentity[]
  groups       ExternalGroup[]
  memberships  ExternalGroupMembership[]
  oauthSessions OauthSession[]

  @@map("tenants")
}

model OauthSession {
  id             String              @id @default(uuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       IntegrationProvider
  state          String              @unique
  status         String              @default("PENDING")
  verifiedEmail  String?             @map("verified_email")
  verifiedDomain String?             @map("verified_domain")
  createdAt      DateTime            @default(now())
  expiresAt      DateTime            @map("expires_at")

  @@index([tenantId])
  @@map("oauth_sessions")
}

model TenantUser {
  id                      String            @id @default(uuid())
  tenantId                String
  tenant                  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                   String
  name                    String
  passwordHash            String
  refreshTokenHash        String?           @map("refresh_token_hash")
  authVersion             Int               @default(0) @map("auth_version")
  role                    Role              @default(USER)
  status                  UserStatus        @default(ACTIVE)
  mfaEnabled              Boolean           @default(false)
  mfaSecret               String?
  lastLoginAt             DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  createdEvents           AuditEvent[]      @relation("AuditActor")
  reviewerReviews         AccessReview[]    @relation("ReviewReviewer")
  submittedRequests       IdentityRequest[] @relation("RequestSubmitter")
  approvedRequests        IdentityRequest[] @relation("RequestApprover")
  mappedExternalIdentities ExternalIdentity[] @relation("MappedIdentity")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("tenant_users")
}

model Invite {
  id         String       @id @default(uuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String
  role       Role         @default(USER)
  token      String       @unique
  status     InviteStatus @default(PENDING)
  invitedBy  String
  acceptedBy String?
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([tenantId])
  @@index([email])
  @@map("invites")
}

model Integration {
  id                String               @id @default(uuid())
  tenantId          String
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider          IntegrationProvider
  name              String
  status            IntegrationStatus    @default(DISCONNECTED)
  externalDomain    String?
  configEncrypted   String?              @map("config_encrypted")
  scopes            String[]             @default([])
  metadata          Json                 @default("{}")
  lastSyncAt        DateTime?            @map("last_sync_at")
  lastSyncStatus    String?              @map("last_sync_status")
  lastSyncError     String?              @map("last_sync_error")
  lastHealthCheckAt DateTime?            @map("last_health_check_at")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  identities        ExternalIdentity[]
  groups            ExternalGroup[]
  memberships       ExternalGroupMembership[]
  reviews           AccessReview[]
  requests          IdentityRequest[]

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("integrations")
}

model ExternalIdentity {
  id               String                   @id @default(uuid())
  tenantId         String
  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      Integration              @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  mappedTenantUserId String?                @map("mapped_tenant_user_id")
  mappedTenantUser TenantUser?              @relation("MappedIdentity", fields: [mappedTenantUserId], references: [id], onDelete: SetNull)
  externalId       String                   @map("external_id")
  primaryEmail     String                   @map("primary_email")
  fullName         String?                  @map("full_name")
  orgUnitPath      String?                  @map("org_unit_path")
  roleNames        String[]                 @default([]) @map("role_names")
  lastLoginAt      DateTime?                @map("last_login_at")
  suspended        Boolean                  @default(false)
  archived         Boolean                  @default(false)
  isAdmin          Boolean                  @default(false) @map("is_admin")
  isDelegatedAdmin Boolean                  @default(false) @map("is_delegated_admin")
  riskScore        Int                      @default(0) @map("risk_score")
  sourceStatus     String                   @default("ACTIVE") @map("source_status")
  rawProfile       Json                     @default("{}") @map("raw_profile")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  memberships      ExternalGroupMembership[]
  reviews          AccessReview[]
  requests         IdentityRequest[]

  @@unique([integrationId, externalId])
  @@unique([integrationId, primaryEmail])
  @@index([tenantId])
  @@index([mappedTenantUserId])
  @@map("external_identities")
}

model ExternalGroup {
  id                String                   @id @default(uuid())
  tenantId          String
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrationId     String
  integration       Integration              @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  externalId        String                   @map("external_id")
  email             String
  name              String
  description       String?
  directMembersCount Int                     @default(0) @map("direct_members_count")
  rawProfile        Json                     @default("{}") @map("raw_profile")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  memberships       ExternalGroupMembership[]
  reviews           AccessReview[]
  requests          IdentityRequest[]

  @@unique([integrationId, externalId])
  @@unique([integrationId, email])
  @@index([tenantId])
  @@map("external_groups")
}

model ExternalGroupMembership {
  id               String          @id @default(uuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      Integration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  externalGroupId  String          @map("external_group_id")
  externalGroup    ExternalGroup   @relation(fields: [externalGroupId], references: [id], onDelete: Cascade)
  externalIdentityId String?       @map("external_identity_id")
  externalIdentity ExternalIdentity? @relation(fields: [externalIdentityId], references: [id], onDelete: SetNull)
  memberExternalId String          @map("member_external_id")
  memberEmail      String?         @map("member_email")
  memberType       String          @map("member_type")
  role             String
  rawProfile       Json            @default("{}") @map("raw_profile")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  reviews          AccessReview[]

  @@unique([externalGroupId, memberExternalId])
  @@index([tenantId])
  @@index([externalIdentityId])
  @@map("external_group_memberships")
}

model AccessReview {
  id               String                  @id @default(uuid())
  tenantId         String
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      Integration             @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  externalIdentityId String                @map("external_identity_id")
  externalIdentity ExternalIdentity        @relation(fields: [externalIdentityId], references: [id], onDelete: Cascade)
  externalGroupId  String                  @map("external_group_id")
  externalGroup    ExternalGroup           @relation(fields: [externalGroupId], references: [id], onDelete: Cascade)
  membershipId     String?                 @map("membership_id")
  membership       ExternalGroupMembership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  reviewerUserId   String?                 @map("reviewer_user_id")
  reviewerUser     TenantUser?             @relation("ReviewReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  reviewAction     String                  @default("REVIEW_ACCESS") @map("review_action")
  status           ReviewStatus            @default(PENDING)
  reviewNotes      String?                 @map("review_notes")
  decisionAppliedAt DateTime?              @map("decision_applied_at")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([tenantId])
  @@index([integrationId])
  @@index([status])
  @@map("access_reviews")
}

model IdentityRequest {
  id                   String          @id @default(uuid())
  tenantId             String
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrationId        String
  integration          Integration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  requesterUserId      String
  requesterUser        TenantUser      @relation("RequestSubmitter", fields: [requesterUserId], references: [id], onDelete: Cascade)
  approverUserId       String?
  approverUser         TenantUser?     @relation("RequestApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  externalIdentityId   String          @map("external_identity_id")
  externalIdentity     ExternalIdentity @relation(fields: [externalIdentityId], references: [id], onDelete: Cascade)
  externalGroupId      String          @map("external_group_id")
  externalGroup        ExternalGroup   @relation(fields: [externalGroupId], references: [id], onDelete: Cascade)
  type                 RequestType
  title                String
  description          String
  requestedAccessRole  String?         @map("requested_access_role")
  status               RequestStatus   @default(PENDING)
  reviewNotes          String?         @map("review_notes")
  reviewedAt           DateTime?       @map("reviewed_at")
  externalOperationStatus String?      @map("external_operation_status")
  externalOperationError String?       @map("external_operation_error")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([tenantId])
  @@index([integrationId])
  @@index([status])
  @@index([type])
  @@map("identity_requests")
}

model AuditEvent {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUserId String?
  actorUser   TenantUser?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  resource    String
  severity    EventSeverity  @default(LOW)
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())

  @@index([tenantId])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_events")
}
