FROM node:20-alpine AS builder
WORKDIR /app
RUN apk add --no-cache python3 make g++ openssl

COPY package*.json ./
COPY tsconfig*.json ./
COPY packages/ ./packages/
COPY apps/control-plane/package.json ./apps/control-plane/package.json

RUN npm ci --ignore-scripts

COPY apps/control-plane/ ./apps/control-plane/
WORKDIR /app/apps/control-plane

RUN npx prisma generate && \
    mkdir -p /app/node_modules/@prisma && \
    if [ -d "/app/apps/node_modules/@prisma/control-plane-client" ]; then \
      cp -r /app/apps/node_modules/@prisma/control-plane-client /app/node_modules/@prisma/control-plane-client; \
    fi
RUN /app/node_modules/.bin/tsc --skipLibCheck
RUN test -f dist/main.js || (echo "ERROR: dist/main.js not found after TypeScript build" && ls -la dist/ 2>/dev/null && exit 1)

FROM node:20-alpine AS runner
RUN apk add --no-cache dumb-init wget openssl
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/control-plane/dist ./dist
COPY --from=builder /app/apps/control-plane/package.json ./
# Prisma client: generated by schema output = "../../node_modules/@prisma/control-plane-client"
# From schema dir (apps/control-plane/prisma/), ../../ = apps/, so client is in apps/node_modules
# We copy it above in builder, so it's now at /app/node_modules/@prisma/control-plane-client
COPY --from=builder /app/node_modules/@prisma/control-plane-client ./node_modules/@prisma/control-plane-client

RUN addgroup -g 1001 -S nodejs && adduser -S nestjs -u 1001 -G nodejs
USER nestjs

EXPOSE 3010
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3010/control/system/health || exit 1
ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "dist/main.js"]
