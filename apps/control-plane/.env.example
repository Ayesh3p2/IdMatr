# Environment Configuration Template
# Copy this file to .env.development, .env.staging, or .env.production
# Replace placeholder values with actual environment-specific values

# Application Configuration
NODE_ENV=development
PORT=3010

# Database Configuration
CONTROL_PLANE_DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# JWT Configuration
JWT_SECRET=your-super-secret-key-32-chars-minimum-length
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Encryption Configuration
ENCRYPTION_KEY=your-encryption-key-32-chars-minimum-length

# MFA Configuration
MFA_ISSUER=idmatr
TOTP_WINDOW=1

# Email Configuration
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@your-domain.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@your-domain.com

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# Monitoring Configuration
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# Development Settings
DEBUG_MODE=false
HOT_RELOAD=false
SWAGGER_ENABLED=true

# External Services
EXTERNAL_API_BASE_URL=https://api.your-domain.com
WEBHOOK_BASE_URL=https://webhooks.your-domain.com

# Security Headers
HELMET_ENABLED=true
RATE_LIMITING_ENABLED=true
SECURITY_HEADERS_ENABLED=true
