# ═══════════════════════════════════════════════════════════════
# IDMatr – Identity Security Platform  |  Environment Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Security ──────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS
ALLOWED_ORIGINS=http://localhost:3000

# ── Databases ─────────────────────────────────────────────────
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
NEO4J_PASSWORD=REPLACE_WITH_STRONG_NEO4J_PASSWORD
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ── Infrastructure (Docker internal URLs) ─────────────────────
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222

# ── Infrastructure (Local dev URLs) ───────────────────────────
# Uncomment when running services directly (not via docker compose)
# REDIS_URL=redis://localhost:6379
# NATS_URL=nats://localhost:4222

# ── Notifications (optional — leave blank to use DEMO_MODE) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@idmatr.com
SLACK_WEBHOOK_URL=

# ── Identity Provider Connectors (optional) ───────────────────
# Microsoft 365 / Azure AD
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DOMAIN=
# GitHub
GITHUB_TOKEN=
# Slack
SLACK_TOKEN=

# ── App Modes ─────────────────────────────────────────────────
# DEMO_MODE=true uses realistic mock data (no external connections needed)
DEMO_MODE=true
NODE_ENV=production
