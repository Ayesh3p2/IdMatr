# IDMatr Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Security ──────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000

# ── Passwords ─────────────────────────────
POSTGRES_PASSWORD=change-me-postgres-password
NEO4J_PASSWORD=change-me-neo4j-password

# ── Infrastructure (Docker internal URLs) ─
# Use these when running via docker compose
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222

# ── Infrastructure (Local dev URLs) ───────
# Use these when running services directly with npm run dev
# REDIS_URL=redis://localhost:6379
# NATS_URL=nats://localhost:4222

# ── Notifications (optional) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SLACK_WEBHOOK_URL=

# ── App Modes ─────────────────────────────
# Set DEMO_MODE=true to use mock data when real DB has no records
DEMO_MODE=true
NODE_ENV=development
