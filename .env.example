# ============================================================
# IDMatr — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Generate secrets:      openssl rand -base64 64
# Hash passwords:        node -e "require('bcryptjs').hash('pw',12).then(console.log)"
# ============================================================

# ── Node Environment ──────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=idmatr
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=idmatr
DATABASE_URL=postgresql://idmatr:change_me_strong_password_here@postgres:5432/idmatr

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=replace_with_strong_random_secret
REDIS_URL=redis://:replace_with_strong_random_secret@redis:6379/0

# ── NATS Messaging ────────────────────────────────────────────
NATS_URL=nats://nats:4222
NATS_API_GATEWAY_PASSWORD=replace_with_strong_random_secret
NATS_IDENTITY_SERVICE_PASSWORD=replace_with_strong_random_secret
NATS_DISCOVERY_SERVICE_PASSWORD=replace_with_strong_random_secret
NATS_GOVERNANCE_SERVICE_PASSWORD=replace_with_strong_random_secret
NATS_RISK_ENGINE_PASSWORD=replace_with_strong_random_secret
NATS_AUDIT_SERVICE_PASSWORD=replace_with_strong_random_secret
NATS_POLICY_ENGINE_PASSWORD=replace_with_strong_random_secret
NATS_GRAPH_SERVICE_PASSWORD=replace_with_strong_random_secret
NATS_NOTIFICATION_SERVICE_PASSWORD=replace_with_strong_random_secret
NATS_WORKER_QUEUE_PASSWORD=replace_with_strong_random_secret

# ── JWT Authentication ────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=8h
INTERNAL_API_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
DATA_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_VALUE

# ── Admin Credentials ─────────────────────────────────────────
ADMIN_EMAIL=admin@yourcompany.com
# Use ADMIN_PASSWORD_HASH (bcrypt) in production — NOT plain text
# node -e "require('bcryptjs').hash('YourPassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# ── Neo4j Graph Database ──────────────────────────────────────
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j_password

# ── API Gateway ───────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=https://app.yourcompany.com,https://admin.yourcompany.com
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
TRUST_PROXY=true

# ── Control Plane ─────────────────────────────────────────────
CONTROL_PLANE_PORT=3010
CONTROL_PLANE_JWT_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
CONTROL_PLANE_DATABASE_URL=postgresql://idmatr:change_me_strong_password_here@postgres:5432/idmatr_db?schema=control_plane
OPERATOR_EMAIL=operator@yourcompany.com
OPERATOR_PASSWORD=replace_with_bootstrap_password
RETENTION_SCAN_ENABLED=true
RETENTION_SCAN_INTERVAL_MS=3600000
IMMUTABLE_AUDIT_LOG_PATH=./var/compliance/operator-audit-ledger.ndjson
IMMUTABLE_AUDIT_SERVICE_PATH=./var/compliance/service-audit-ledger.ndjson

# ── Admin Dashboard (Next.js) ─────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourcompany.com

# ── Microsoft 365 / Azure AD ──────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── Google Workspace ──────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_ADMIN_EMAIL=
GOOGLE_DOMAIN=

# ── Slack ─────────────────────────────────────────────────────
SLACK_TOKEN=
SLACK_WEBHOOK_URL=

# ── GitHub ────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_ORG=

# ── Notifications ──────────────────────────────────────────────
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=notifications@yourcompany.com
SMTP_PASS=

# ── Observability ──────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=log
