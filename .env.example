NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3001

POSTGRES_DB=idmatr
POSTGRES_USER=idmatr
POSTGRES_PASSWORD=idmatr_dev_password
DATABASE_URL=postgresql://idmatr:idmatr_dev_password@localhost:5432/idmatr?schema=public

JWT_SECRET=local-dev-jwt-secret-change-me
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
DATA_ENCRYPTION_KEY=replace-with-strong-random-secret

BOOTSTRAP_TENANT_NAME=IDMatr
BOOTSTRAP_TENANT_SLUG=idmatr
BOOTSTRAP_TENANT_DOMAIN=idmatr.local
BOOTSTRAP_ADMIN_NAME=Platform Admin
BOOTSTRAP_ADMIN_EMAIL=admin@idmatr.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"your-key-id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"google-sync@your-project.iam.gserviceaccount.com","client_id":"1234567890"}
GOOGLE_ADMIN_EMAIL=admin@yourdomain.com
GOOGLE_DOMAIN=yourdomain.com

ITDR_INACTIVE_DAYS=90
