generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  timestamp   DateTime @default(now())
  actorId     String
  actorType   String   // user, system, service
  action      String   // login, access_request, app_discovery, etc.
  targetId    String
  targetType  String
  status      String   // success, failure
  details     Json?
  ipAddress   String?
  userAgent   String?
  previousHash String?
  entryHash    String?

  @@index([tenantId])
  @@index([tenantId, timestamp])
}
