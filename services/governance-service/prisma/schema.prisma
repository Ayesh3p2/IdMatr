generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ApprovalWorkflow {
  id               String   @id @default(uuid())
  requestType      String   // access_request, role_change, certification
  requesterId      String
  targetId         String
  status           String   // pending, approved, rejected, escalated
  currentApproverId String
  slaDueDate       DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  history          WorkflowHistory[]
}

model WorkflowHistory {
  id                String           @id @default(uuid())
  workflowId        String
  workflow          ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  approverId        String
  action            String           // approve, reject, comment
  timestamp         DateTime         @default(now())
  comment           String?
}

model CertificationCampaign {
  id            String   @id @default(uuid())
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime
  status        String   // active, completed, cancelled
  reviewers     String[] // list of user ids
  targetApps    String[] // list of app ids
}
