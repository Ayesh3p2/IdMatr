// Policy Engine Prisma Schema
// Connects to the same DB as identity-service (identity_service schema)
// for RBAC policy enforcement

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  status      String
  riskScore   Float    @default(0)
  lastLogin   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  metadata    Json?
  accessGrants AccessGrant[]

  @@map("User")
}

model Application {
  id              String   @id @default(uuid())
  name            String
  type            String
  discoverySource String
  riskScore       Float    @default(0)
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  accessGrants    AccessGrant[]
  roles           Role[]

  @@map("Application")
}

model Role {
  id            String   @id @default(uuid())
  name          String
  description   String?
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  permissions   Permission[]
  accessGrants  AccessGrant[]

  @@map("Role")
}

model Permission {
  id          String   @id @default(uuid())
  name        String
  description String?
  riskLevel   String
  action      String?  // e.g. "read", "write", "delete", "admin"
  resource    String?  // e.g. "users", "applications", "*"
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id])

  @@map("Permission")
}

model AccessGrant {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  grantedAt     DateTime @default(now())
  expiresAt     DateTime?
  status        String

  @@map("AccessGrant")
}
