{
  "name": "idmatr",
  "version": "1.0.0",
  "private": true,
  "description": "IDMatr monolith-first SaaS core",
  "workspaces": [
    "apps/control-plane"
  ],
  "scripts": {
    "build": "npm --workspace apps/control-plane run build",
    "start": "npm --workspace apps/control-plane run start",
    "dev": "npm --workspace apps/control-plane run start:dev",
    "test": "npm --workspace apps/control-plane run test",
    "test:core-validation": "npm --workspace apps/control-plane run test:core-validation",
    "db:generate": "npm --workspace apps/control-plane run db:generate",
    "db:push": "npm --workspace apps/control-plane run db:push",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
