# ═══════════════════════════════════════════════════════════════════════════════
# IDMatr Platform — Production Environment Template
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY REQUIREMENTS:
# - All secrets are REQUIRED (no defaults)
# - All values must be generated during initial deployment
# - Never commit actual secrets to git
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN
NEO4J_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────────────────
# API GATEWAY (port 3001)
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret for tenant authentication — must be cryptographically secure
JWT_SECRET=REPLACE_WITH_RANDOM_JWT_SECRET_64_CHARS_MIN

# JWT token expiration
JWT_EXPIRES_IN=8h

# CORS origins — restrict to your domain(s)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Admin credentials for initial setup — CHANGE AFTER FIRST LOGIN
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN

# Demo mode — MUST be false in production
DEMO_MODE=false

# ─────────────────────────────────────────────────────────────────────────────
# CONTROL PLANE (port 3010) — Operator Portal
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret for control plane — separate from API gateway
CONTROL_PLANE_JWT_SECRET=REPLACE_WITH_RANDOM_JWT_SECRET_64_CHARS_MIN

# Control plane token expiration
CONTROL_PLANE_JWT_EXPIRES_IN=8h

# Operator account — auto-generated during initialization
# DO NOT SET MANUALLY — will be generated and printed during system bootstrap
OPERATOR_EMAIL=
OPERATOR_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY KEYS & ENCRYPTION
# ─────────────────────────────────────────────────────────────────────────────

# Field-level encryption key (AES-256-GCM) for sensitive data
# Generate with: openssl rand -base64 32
DATA_ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCRYPTION_KEY_32_BYTES

# Salt for password hashing
HASH_SALT=REPLACE_WITH_RANDOM_SALT_32_CHARS

# ─────────────────────────────────────────────────────────────────────────────
# DISCOVERY INTEGRATIONS
# ─────────────────────────────────────────────────────────────────────────────

# Google Workspace
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_ADMIN_EMAIL=
GOOGLE_DOMAIN=

# Microsoft 365 / Azure AD
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=

# Slack
SLACK_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND URLS
# ─────────────────────────────────────────────────────────────────────────────

# Admin Dashboard API endpoint
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Control Plane UI API endpoint
NEXT_PUBLIC_CP_API_URL=https://control-plane.yourdomain.com

# Control Plane UI URL (backend reference)
CONTROL_PLANE_UI_URL=https://control-plane-ui.yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL / NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SLACK_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# REDIS (for worker queue)
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379

# ═══════════════════════════════════════════════════════════════════════════════
# GENERATION SCRIPT
# ═══════════════════════════════════════════════════════════════════════════════
# Run scripts/generate-env.sh to auto-fill REPLACE_WITH_* values with secure
# random values, then review and customize for your deployment
# ═══════════════════════════════════════════════════════════════════════════════
